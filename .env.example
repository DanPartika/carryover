# Copy to ".env". ".env" is git-ignored.

# --- App database (both containers read these via env_file) ---
POSTGRES_USER=carryover
POSTGRES_PASSWORD=change-me-in-prod
POSTGRES_DB=carryover
# App builds its connection string from POSTGRES_* + this host (override for host-run dev):
CARRYOVER_DB_HOST=carryover-db
CARRYOVER_DB_PORT=5432

# --- Login with Lithe (unset both NEXT_PUBLIC_LITHE_ISSUER and _CLIENT_ID = standalone, auth off) ---
NEXT_PUBLIC_LITHE_ISSUER=http://localhost:8080
NEXT_PUBLIC_LITHE_CLIENT_ID=            # minted at registration; NEXT_PUBLIC_* inlined at BUILD time
NEXT_PUBLIC_LITHE_CORE_URL=http://localhost:3000   # portal origin; nginx proxies /v1
NEXT_PUBLIC_BASE_PATH=/apps/carryover

# --- AI (PRD §3: plan drafts + adherence summaries, both via the platform /v1/ai gateway) ---
CARRYOVER_AI_MODE=fixture               # lithe | fixture
CARRYOVER_PLAN_MODEL=claude-sonnet-5
CARRYOVER_SUMMARY_MODEL=claude-haiku-4-5

# --- App admins (comma-separated emails): granted is_app_admin at login.
#     App admins create clinics; PTs/clinic admins manage people within them. ---
CARRYOVER_ADMIN_EMAILS=

# --- Dev-only escape hatch: fake user when auth is off. NEVER set in prod.
#     The dev user is always an app admin. ---
CARRYOVER_ALLOW_DEV_USER=
